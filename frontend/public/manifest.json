{
  "name": "Premium - Video Streaming",
  "short_name": "Premium",
  "description": "A modern YouTube-like video streaming platform with background playback",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#000000",
